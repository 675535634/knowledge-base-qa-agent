<Window x:Class="KnowledgeBaseQaAgent.Desktop.DesktopPetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:KnowledgeBaseQaAgent.Desktop.Models"
        Width="430"
        Height="360"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        PreviewKeyDown="Window_PreviewKeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp">
    <Window.Resources>
        <RadialGradientBrush x:Key="PetIdleBrush" GradientOrigin="0.35,0.25" Center="0.42,0.38" RadiusX="0.72" RadiusY="0.72">
            <GradientStop Color="#F5FFF8" Offset="0" />
            <GradientStop Color="#B9E3C6" Offset="0.52" />
            <GradientStop Color="#83C99A" Offset="1" />
        </RadialGradientBrush>
        <Storyboard x:Key="BobStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="PetBodyTranslate"
                             Storyboard.TargetProperty="Y"
                             From="0"
                             To="-8"
                             Duration="0:0:0.75" />
        </Storyboard>
    </Window.Resources>
    <Grid>
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="打开问答" Click="OpenVisitorMenuItem_Click" />
                <Separator />
                <MenuItem Header="退出" Click="ExitMenuItem_Click" />
            </ContextMenu>
        </Grid.ContextMenu>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard Storyboard="{StaticResource BobStoryboard}" />
            </EventTrigger>
        </Grid.Triggers>
        <Canvas>
            <Grid x:Name="PetContainer" Width="210" Height="250" Canvas.Left="110" Canvas.Top="34">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="PetBodyTranslate" />
                </Grid.RenderTransform>
                <Image Source="{Binding AvatarImagePath}"
                       Stretch="Uniform"
                       Visibility="{Binding CustomAvatarVisibility}"
                       Width="210"
                       Height="250"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <Grid Visibility="{Binding BuiltInAvatarVisibility}">
                    <Grid.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="8" Opacity="0.2" Color="#35445A" />
                    </Grid.Effect>
                    <Ellipse x:Name="Body" Width="116" Height="126" Stroke="#1D2433" StrokeThickness="3" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{StaticResource PetIdleBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding State}" Value="{x:Static models:AvatarState.Listening}">
                                    <Setter Property="Fill" Value="#A7F3D0" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding State}" Value="{x:Static models:AvatarState.Thinking}">
                                    <Setter Property="Fill" Value="#FDE68A" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding State}" Value="{x:Static models:AvatarState.Speaking}">
                                    <Setter Property="Fill" Value="#DDD6FE" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding State}" Value="{x:Static models:AvatarState.Error}">
                                    <Setter Property="Fill" Value="#FCA5A5" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                    </Ellipse>
                    <Ellipse Width="42" Height="54" Fill="{StaticResource PetIdleBrush}" Stroke="#1D2433" StrokeThickness="3" HorizontalAlignment="Left" Margin="18,8,0,0" VerticalAlignment="Top" />
                    <Ellipse Width="42" Height="54" Fill="{StaticResource PetIdleBrush}" Stroke="#1D2433" StrokeThickness="3" HorizontalAlignment="Right" Margin="0,8,18,0" VerticalAlignment="Top" />
                    <Ellipse Width="16" Height="18" Fill="#1D2433" HorizontalAlignment="Left" Margin="50,58,0,0" VerticalAlignment="Top" />
                    <Ellipse Width="16" Height="18" Fill="#1D2433" HorizontalAlignment="Right" Margin="0,58,50,0" VerticalAlignment="Top" />
                    <Path Data="M 62 92 Q 75 105 88 92" Stroke="#1D2433" StrokeThickness="3" Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                    <Ellipse x:Name="StateDot" Width="22" Height="22" Stroke="White" StrokeThickness="3" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,16,20">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#2D7FF9" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding State}" Value="{x:Static models:AvatarState.Listening}">
                                    <Setter Property="Fill" Value="#24A148" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding State}" Value="{x:Static models:AvatarState.Thinking}">
                                    <Setter Property="Fill" Value="#F59E0B" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding State}" Value="{x:Static models:AvatarState.Speaking}">
                                    <Setter Property="Fill" Value="#8B5CF6" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding State}" Value="{x:Static models:AvatarState.Error}">
                                    <Setter Property="Fill" Value="#DC2626" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                    </Ellipse>
                </Grid>
            </Grid>
            <Border x:Name="HintBubble"
                    Width="190"
                    Background="#F7FBFFFF"
                    BorderBrush="#DDE3EA"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14,9"
                    Canvas.Left="139"
                    Canvas.Top="280">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="4" Opacity="0.16" Color="#50608A" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{Binding StatusText}" Foreground="#1D2433" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding PetHintText}" Foreground="#697386" FontSize="12" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,3,0,0" />
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</Window>
