<Project Sdk="WixToolset.Sdk/5.0.2">
  <PropertyGroup>
    <OutputName>KnowledgeBaseQaAgent</OutputName>
    <Platform>x64</Platform>
    <InstallerPlatform>x64</InstallerPlatform>
    <DefineConstants>DesktopProjectDir=..\..\src\KnowledgeBaseQaAgent.Desktop</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="WixToolset.UI.wixext" Version="5.0.2" />
    <ProjectReference Include="..\..\src\KnowledgeBaseQaAgent.Desktop\KnowledgeBaseQaAgent.Desktop.csproj"
                      Publish="true"
                      Properties="PublishProfile=win-x64-self-contained" />
  </ItemGroup>
</Project>
