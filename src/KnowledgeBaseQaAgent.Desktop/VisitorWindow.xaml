<Window x:Class="KnowledgeBaseQaAgent.Desktop.VisitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding VisitorWindowTitle}"
        Width="1220"
        Height="760"
        MinWidth="1040"
        MinHeight="660"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Icon="{Binding LogoPreviewImagePath}"
        Background="#F7F9FF"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">
    <Window.Resources>
        <LinearGradientBrush x:Key="PageBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FBFCFF" Offset="0" />
            <GradientStop Color="#F2F5FF" Offset="0.48" />
            <GradientStop Color="#EEF7FF" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#7267FF" Offset="0" />
            <GradientStop Color="#8FA2FF" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="Ink" Color="#202744" />
        <SolidColorBrush x:Key="Muted" Color="#77809A" />
        <SolidColorBrush x:Key="Line" Color="#DDE5F5" />
        <DropShadowEffect x:Key="SoftShadow" BlurRadius="24" ShadowDepth="8" Opacity="0.12" Color="#6370B8" />

        <DataTemplate x:Key="ButtonTextTemplate">
            <TextBlock Text="{Binding}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       LineStackingStrategy="BlockLineHeight"
                       LineHeight="20" />
        </DataTemplate>

        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="#EEFFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Effect" Value="{StaticResource SoftShadow}" />
        </Style>

        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="MinHeight" Value="48" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="ContentTemplate" Value="{StaticResource ButtonTextTemplate}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="24">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,0" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.58" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource PillButton}">
            <Setter Property="Foreground" Value="#5661D8" />
            <Setter Property="Background" Value="#F7F8FF" />
            <Setter Property="BorderBrush" Value="#DFE4FF" />
        </Style>

        <Style x:Key="QuickButton" TargetType="Button">
            <Setter Property="MinHeight" Value="68" />
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#28304F" />
            <Setter Property="Background" Value="#F8FAFF" />
            <Setter Property="BorderBrush" Value="#DFE5FF" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ContentTemplate" Value="{StaticResource ButtonTextTemplate}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="18">
                            <Grid Margin="16,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="✦" FontSize="18" Foreground="#7C83FF" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource Ink}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PageBackground}">
        <Grid>
            <TextBlock Text="✦" FontSize="72" Foreground="#2B6CFF" Opacity="0.05" Margin="86,108,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
            <TextBlock Text="✧" FontSize="96" Foreground="#7C83FF" Opacity="0.06" Margin="0,24,128,0" HorizontalAlignment="Right" VerticalAlignment="Top" />
            <TextBlock Text="✦" FontSize="120" Foreground="#56C6FF" Opacity="0.05" Margin="0,0,48,42" HorizontalAlignment="Right" VerticalAlignment="Bottom" />
        </Grid>

        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource Panel}" Padding="22,14" MinHeight="82">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="320" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="52" Height="52" CornerRadius="18" Background="#FFFFFF" BorderBrush="#E2E7FF" BorderThickness="1" Margin="0,0,14,0" ClipToBounds="True">
                            <Image Source="{Binding LogoPreviewImagePath}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding VisitorHeadline}" FontSize="23" FontWeight="SemiBold" Foreground="{StaticResource Ink}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding WakeHintText}" FontSize="14" Foreground="{StaticResource Muted}" Margin="0,4,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                    <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" MaxWidth="470">
                        <Border Background="#EAF9F0" CornerRadius="14" Padding="12,6" MinWidth="78" MinHeight="34" Margin="0,0,12,6">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="#4ACB75" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding Status}" Foreground="#2D8F51" FontSize="13" FontWeight="SemiBold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" MaxWidth="130" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Button Content="{Binding EndSessionButtonText}" Style="{StaticResource GhostButton}" MinWidth="118" MaxWidth="170" Margin="0,0,10,6" Click="EndSessionButton_Click" />
                        <Button Content="{Binding CloseButtonText}" Style="{StaticResource GhostButton}" MinWidth="82" MaxWidth="120" Margin="0,0,0,6" Click="CloseButton_Click" />
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="270" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="290" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Panel}" Padding="20" Margin="0,0,18,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="{Binding QuickQuestionsHeader}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource Ink}" />
                            <TextBlock Text="{Binding GreetingText}" TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource Muted}" Margin="0,8,0,0" />
                        </StackPanel>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding QuickQuestions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource QuickButton}"
                                                Content="{Binding Text}"
                                                Command="{Binding DataContext.AskQuickQuestionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Panel}" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,14">
                                <TextBlock Text="{Binding ConversationHeader}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource Ink}" />
                                <TextBlock Text="  ✧" FontSize="20" Foreground="#8B93FF" />
                            </DockPanel>
                            <ListBox x:Name="ConversationList"
                                     Grid.Row="1"
                                     ItemsSource="{Binding Conversation}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.CanContentScroll="False"
                                     VirtualizingPanel.IsVirtualizing="False">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,0,0,14" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding BubbleBackground}" BorderBrush="#E7EBFA" BorderThickness="1" CornerRadius="18" Padding="16" MaxWidth="620" HorizontalAlignment="{Binding BubbleAlignment}">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="18" ShadowDepth="5" Opacity="0.08" Color="#6670B8" />
                                            </Border.Effect>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="42" Height="42" CornerRadius="21" Background="#EEF1FF" Margin="0,0,10,0" ClipToBounds="True">
                                                        <Grid>
                                                            <Image Source="{Binding AssistantAvatarPath}"
                                                                   Visibility="{Binding AssistantAvatarVisibility}"
                                                                   Stretch="UniformToFill"
                                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                                            <TextBlock Text="{Binding AvatarSymbol}"
                                                                       Visibility="{Binding UserAvatarVisibility}"
                                                                       Foreground="{Binding AccentColor}"
                                                                       FontSize="16"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" />
                                                            <TextBlock Text="{Binding AvatarSymbol}"
                                                                       Visibility="{Binding AssistantSymbolVisibility}"
                                                                       Foreground="{Binding AccentColor}"
                                                                       FontSize="16"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Border>
                                                    <TextBlock Text="{Binding RoleDisplay}" Foreground="{Binding AccentColor}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Margin="44,8,0,0" FontSize="16" LineHeight="25" Foreground="{StaticResource Ink}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource Panel}" Padding="12" Margin="0,16,0,0" MinHeight="86">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#F8FAFF" BorderBrush="#E1E7FA" BorderThickness="1" CornerRadius="24" Margin="0,0,12,0">
                                <TextBox Text="{Binding Question, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputBox}"
                                         TextWrapping="Wrap"
                                         KeyDown="QuestionBox_KeyDown" />
                            </Border>
                            <Button Grid.Column="1"
                                    Content="{Binding SendButtonText}"
                                    Style="{StaticResource GhostButton}"
                                    MinWidth="96"
                                    MaxWidth="130"
                                    Margin="0"
                                    Command="{Binding AskCommand}" />
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Column="2" Style="{StaticResource Panel}" Padding="18" Margin="18,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="230" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" CornerRadius="22" Background="#F3F6FF" ClipToBounds="True">
                            <Grid>
                                <Rectangle>
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#E8EBFF" Offset="0" />
                                            <GradientStop Color="#FDF5FF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <TextBlock Text="✦" FontSize="52" Foreground="#FFFFFF" Opacity="0.8" Margin="18,14,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
                                <TextBlock Text="✧" FontSize="64" Foreground="#7C83FF" Opacity="0.2" Margin="0,0,18,18" HorizontalAlignment="Right" VerticalAlignment="Bottom" />
                                <Image Source="{Binding PetPreviewImagePath}" Stretch="Uniform" Margin="24,10" RenderOptions.BitmapScalingMode="HighQuality" />
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="1" Margin="0,18,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding AssistantName}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource Ink}" TextWrapping="Wrap" MaxWidth="170" />
                                <Border Background="#EAF9F0" CornerRadius="12" Padding="9,4" MinWidth="58" MinHeight="28" Margin="10,1,0,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="7" Height="7" Fill="#4ACB75" VerticalAlignment="Center" Margin="0,0,5,0" />
                                        <TextBlock Text="可用" Foreground="#2D8F51" FontSize="12" TextWrapping="NoWrap" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="{Binding GreetingText}" TextWrapping="Wrap" Foreground="{StaticResource Muted}" FontSize="14" TextAlignment="Center" Margin="4,10,4,0" />
                        </StackPanel>

                        <ItemsControl Grid.Row="2" ItemsSource="{Binding AssistantTags}" Margin="0,22,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F7F8FF" BorderBrush="#E2E7FF" BorderThickness="1" CornerRadius="14" Padding="12,9" Margin="6">
                                        <TextBlock Text="{Binding Text}" Foreground="#6370D8" FontWeight="SemiBold" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Grid.Row="4">
                            <Border Background="#F7F8FF" BorderBrush="#E2E7FF" BorderThickness="1" CornerRadius="16" Padding="12,10" Margin="0,0,0,10">
                                <TextBlock Text="{Binding VoiceInteractionHint}" Foreground="{StaticResource Muted}" FontSize="14" TextWrapping="Wrap" TextAlignment="Center" LineHeight="20" />
                            </Border>
                            <Button Content="{Binding VoiceAskButtonDisplayText}" Style="{StaticResource PillButton}" Margin="0,0,0,10" Command="{Binding VoiceAskCommand}" />
                            <Button Content="{Binding EndSessionButtonText}" Style="{StaticResource GhostButton}" Margin="0,0,0,10" Click="EndSessionButton_Click" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
